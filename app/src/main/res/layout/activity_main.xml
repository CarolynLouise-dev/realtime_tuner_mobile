<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipChildren="false">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.05"
        android:background="@drawable/cat" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="GUITAR TUNA"
        android:textColor="#D9CFCF"
        android:letterSpacing="0.4"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/auto_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="AUTO ●"
        android:textColor="#1ABC9C"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/note_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintVertical_bias="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gauge_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_direction_hint"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="TUNE UP!"
            android:textColor="#E74C3C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/txt_current_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D#2"
            android:layout_marginTop="100dp"
            android:textColor="#FFFFFF"
            android:textSize="50sp"
            android:fontFamily="sans-serif-condensed-light"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/gauge_container"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingHorizontal="40dp"
        app:layout_constraintBottom_toTopOf="@id/headstock_area"
        app:layout_constraintTop_toBottomOf="@id/note_area">


        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:layout_gravity="center_vertical"
            android:background="#423131" />

        <FrameLayout
            android:id="@+id/pointer_wrapper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clipChildren="false">



            <TextView
                android:id="@+id/txt_bubble_cents"
                android:layout_width="40dp"
                android:layout_gravity="center"
                android:layout_height="40dp"
                android:background="@drawable/cents_bubble_bg"
                android:rotation="-45"
                android:elevation="8dp" />



            <View
                android:layout_width="10dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:background="#1ABC9C"
                android:elevation="4dp" />


        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/headstock_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:clipChildren="false"
        app:layout_constraintBottom_toTopOf="@id/footer_info"
        android:layout_marginBottom="40dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/btn_d3" style="@style/PegStyle" android:text="D" />
            <TextView android:id="@+id/btn_a2" style="@style/PegStyle" android:layout_marginVertical="20dp" android:text="A" />
            <TextView android:id="@+id/btn_e2" style="@style/PegStyle" android:text="E" />
        </LinearLayout>

        <ImageView
            android:layout_width="140dp"
            android:layout_height="200dp"
            android:src="@drawable/guitar_header"
            android:alpha="0.85"
            android:scaleType="fitCenter"
            android:layout_marginHorizontal="20dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/btn_g3" style="@style/PegStyle" android:text="G" />
            <TextView android:id="@+id/btn_b3" style="@style/PegStyle" android:layout_marginVertical="20dp" android:text="B" />
            <TextView android:id="@+id/btn_e4" style="@style/PegStyle" android:text="E" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="horizontal">
        <TextView android:id="@+id/txt_hz" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="79.53 Hz" android:textColor="#FFFFFF" android:textSize="12sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/txt_cents_raw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="38.53 cts" android:textColor="#FFFFFF" android:textSize="12sp" android:fontFamily="monospace"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipChildren="false">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="GUITAR TUNA"
        android:textColor="#888888"
        android:letterSpacing="0.3"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/auto_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="AUTO ●"
        android:textColor="#1ABC9C"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/note_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintVertical_bias="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gauge_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_direction_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUNE UP!"
            android:textColor="#E74C3C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/txt_current_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="80sp"
            android:fontFamily="sans-serif-thin"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/gauge_container"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:paddingHorizontal="40dp"
        app:layout_constraintBottom_toTopOf="@id/headstock_area"
        app:layout_constraintTop_toBottomOf="@id/note_area">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="#333333" />

        <View
            android:layout_width="4dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:background="#1ABC9C" />

        <FrameLayout
            android:id="@+id/pointer_wrapper"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:clipChildren="false">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="5dp">

                <View
                    android:id="@+id/txt_bubble_cents"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/cents_bubble_bg"
                    android:rotation="-45" />

                <TextView
                    android:id="@+id/txt_cents_raw"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <View
                android:layout_width="10dp"
                android:layout_height="60dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="#1ABC9C" />
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/headstock_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/footer_info"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/btn_d3" style="@style/PegStyle" android:text="D" />
            <TextView android:id="@+id/btn_a2" style="@style/PegStyle" android:layout_marginVertical="15dp" android:text="A" />
            <TextView android:id="@+id/btn_e2" style="@style/PegStyle" android:text="E" />
        </LinearLayout>

        <ImageView
            android:layout_width="120dp"
            android:layout_height="180dp"
            android:src="@drawable/guitar_header"
            android:alpha="0.6"
            android:scaleType="fitCenter"
            android:layout_marginHorizontal="20dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/btn_g3" style="@style/PegStyle" android:text="G" />
            <TextView android:id="@+id/btn_b3" style="@style/PegStyle" android:layout_marginVertical="15dp" android:text="B" />
            <TextView android:id="@+id/btn_e4" style="@style/PegStyle" android:text="E" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/txt_hz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0.00 Hz"
            android:textColor="#444444"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>